---
import "../styles/global.css";
interface Props {
  title?: string;
}

const { title: _title } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title ? `${title} | BoilrJs` : "BoilrJs | Web Framework"}</title>
    <script defer src="https://cloud.umami.is/script.js" data-website-id="2933fd93-6229-420e-95c4-56800fb6ebad"></script>
  </head>
  <body><slot /></body>
</html>

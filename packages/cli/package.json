{
  "name": "@boilrjs/cli",
  "version": "0.2.1",
  "description": "CLI tool for BoilrJs framework",
  "author": {
    "name": "Rhinolabs Agency",
    "email": "hello@rhinolabs.agency",
    "url": "https://rhinolabs.agency"
  },
  "type": "module",
  "exports": "./dist/index.js",
  "bin": {
    "boilrjs": "./bin/run.js"
  },
  "files": [
    "/bin",
    "/dist",
    "/src/templates"
  ],
  "keywords": [
    "cli",
    "boilrjs",
    "framework",
    "fastify",
    "tool",
    "generator",
    "scaffolding",
    "typescript"

  "scripts": {
    "build": "rm -rf dist && tsc && cp -R src/templates dist",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rhinolabs/boilr.git",
    "directory": "packages/cli"
  },
  "license": "MIT"
}
